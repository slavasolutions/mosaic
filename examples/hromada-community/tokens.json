{
  "color": {
    "background": { "$value": "#fffdf7", "$type": "color" },
    "text":       { "$value": "#1a1a1a", "$type": "color" },
    "accent":     { "$value": "#005bbb", "$type": "color" },
    "muted":      { "$value": "#6b6b6b", "$type": "color" }
  },
  "font": {
    "body":      { "$value": "system-ui, sans-serif", "$type": "fontFamily" },

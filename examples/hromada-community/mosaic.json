{
  "$schema": "https://mosaic.dev/schemas/0.8.json",
  "version": "0.8",
  "site": {
    "name": "Hromada Community",
    "locale": "en-CA",
    "url": "https://hromada.example.org"
  },
  "types": {
    "NewsItem": {
      "fields": {
        "title": { "type": "string", "required": true },
        "date": { "type": "date", "required": true },
        "summary": { "type": "string" },
        "hero": { "type": "asset" },
        "body": { "type": "markdown" }
      }
    },
    "TeamMember": {
      "fields": {
        "title": { "type": "string", "required": true },
        "role": { "type": "string", "required": true },
        "email": { "type": "string" },
        "photo": { "type": "asset" },
        "colleagues": { "type": "array", "of": { "kind": "ref", "to": "team" } },
        "bio": { "type": "markdown" }
      }
    },
    "Service": {
      "fields": {
        "title": { "type": "string", "required": true },
        "summary": { "type": "string", "required": true },
        "icon": { "type": "asset" },
        "body": { "type": "markdown" }
      }
    },
    "Event": {
      "fields": {
        "title": { "type": "string", "required": true },
        "date": { "type": "date", "required": true },
        "location": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "SiteConfig": {
      "fields": {
        "name": { "type": "string", "required": true },
        "tagline": { "type": "string" },
        "contact": { "type": "object" }
      }
    },
    "Header": {
      "fields": {
        "logo": { "type": "asset" },
        "nav": { "type": "array", "of": { "kind": "object", "fields": {
          "label": { "type": "string", "required": true },
          "url": { "type": "string", "required": true }
        } } }
      }
    },
    "Footer": {
      "fields": {
        "copyright": { "type": "string" },
        "links": { "type": "array", "of": { "kind": "object", "fields": {
          "label": { "type": "string", "required": true },
          "url": { "type": "string", "required": true }
        } } }
      }
    },
    "DesignTokens": {
      "description": "DTCG-shaped design tokens. Free-form: Mosaic does not validate DTCG internals (SPEC §10; empty `fields` is the opaque-type escape hatch).",
      "fields": {}
    }
  },
  "collections": {
    "news": {
      "type": "NewsItem",
      "defaultSort": "date desc",
      "defaultMount": "/news"
    },
    "team": {
      "type": "TeamMember",
      "defaultSort": "title asc",
      "defaultMount": "/team"
    },
    "services": {
      "type": "Service",
      "defaultMount": "/services"
    },
    "events": {
      "type": "Event",
      "defaultSort": "date asc",
      "defaultMount": "/events"
    }
  },
  "singletons": {
    "site": { "type": "SiteConfig" },
    "header": { "type": "Header" },
    "footer": { "type": "Footer" },
    "tokens": { "type": "DesignTokens" }
  },
  "redirects": [
    { "from": "/news/launch", "to": "/news/2025-03-12-launch", "status": 301 }
  ]
}
